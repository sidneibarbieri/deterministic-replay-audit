# ActionAudit - optional API keys
# Copy to .env and fill with your keys. All keys are optional.
# Tier 0 features (portfolio, prices, analysis) work without any keys via Yahoo Finance.

SEC_USER_AGENT="ActionAudit Reviewer user@example.com"
FRED_API_KEY=
OPENFIGI_API_KEY=
ALPHAVANTAGE_API_KEY=
FMP_API_KEY=
FINANCIALMODELINGPREP_API_KEY=
FINNHUB_API_KEY=
PATENTSVIEW_API_KEY=
OPENALEX_MAILTO=
MASSIVE_API_KEY=

# Azure OpenAI - only needed to collect real advisor runs for the audit study.
# The collector is budget-guarded (--max-calls) and caches every run to JSON.
ADVISOR_LLM_PROVIDER=azure
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_MODEL=
AZURE_OPENAI_API_VERSION=2024-10-21

# OpenAI - used for provider-comparison experiments.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic - used for provider-comparison experiments.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_BASE_URL=https://api.anthropic.com
