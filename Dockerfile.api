FROM python:3.11-slim

WORKDIR /app

COPY pyproject.toml uv.lock README.md ./
COPY src ./src
COPY data ./data

ENV PYTHONPATH=/app

RUN pip install --no-cache-dir uv==0.11.6 \
    && uv sync --frozen

EXPOSE 8000

CMD [".venv/bin/uvicorn", "arenawealth.api.main:app", "--host", "0.0.0.0", "--port", "8000"]
